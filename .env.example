# ── LLM Configuration ────────────────────────────────────────────────────────
# OpenAI-compatible endpoint (e.g. HuggingFace Inference API)
API_BASE_URL=https://api-inference.huggingface.co/v1

# Model identifier on HuggingFace (e.g. mistralai/Mistral-7B-Instruct-v0.3)
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Your HuggingFace API token (get it from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── PipelineRx Server ─────────────────────────────────────────────────────────
# URL where the FastAPI server is running (default is fine for local dev)
ENV_URL=http://localhost:7860
